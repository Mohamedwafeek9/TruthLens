PYTHONUNBUFFERED=1
TRUTHLENS_HOST=0.0.0.0
TRUTHLENS_PORT=5050
TRUTHLENS_SECRET_KEY=replace-with-output-of-python-secrets-token-hex
TRUTHLENS_AUTOSTART_DETECTION=true

# Password hashes generated with:
# /opt/truthlens-pro/.venv/bin/python /opt/truthlens-pro/scripts/make-password-hash.py
TRUTHLENS_ADMIN_PASSWORD_HASH=
TRUTHLENS_DRM_PASSWORD_HASH=
TRUTHLENS_DRSARA_PASSWORD_HASH=

# Camera defaults for Raspberry Pi 5 + Bookworm + Picamera2.
TRUTHLENS_CAMERA_WIDTH=1280
TRUTHLENS_CAMERA_HEIGHT=720
TRUTHLENS_CAMERA_FPS=25
TRUTHLENS_CAMERA_FORMAT=BGR888
TRUTHLENS_CAMERA_BUFFERS=4
TRUTHLENS_QUEUE_FRAMES=false
TRUTHLENS_CAMERA_WARMUP_SEC=1.5
TRUTHLENS_CAMERA_WARMUP_FRAMES=8
TRUTHLENS_CAMERA_RECONNECT_SEC=2.0
TRUTHLENS_AWB_MODE=auto
TRUTHLENS_FLICKER_HZ=50

# Use manual gains only for fixed lighting after calibration.
# TRUTHLENS_COLOUR_GAINS=1.6,1.3

# YOLO and streaming.
TRUTHLENS_INF_WIDTH=640
TRUTHLENS_INF_HEIGHT=480
TRUTHLENS_OBJECT_STRIDE=2
TRUTHLENS_POSE_CONF=0.38
TRUTHLENS_OBJECT_CONF=0.32
TRUTHLENS_TORCH_THREADS=3
TRUTHLENS_JPEG_QUALITY=82
TRUTHLENS_STREAM_INTERVAL_SEC=0.04
TRUTHLENS_WAITRESS_THREADS=8
